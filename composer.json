{
  "name": "mammatus/groups",
  "description": "\ud83d\udc69\u200d\ud83d\udc69\u200d\ud83d\udc67\u200d\ud83d\udc66 All groups related tooling",
  "license": "MIT",
  "type": "composer-plugin",
  "require": {
    "php": "^8.4",
    "composer-plugin-api": "^2.0",
    "mammatus/life-cycle-events": "dev-switch-to-groups as 2.4.0",
    "wyrihaximus/broadcast-contracts": "^1.3.0",
    "wyrihaximus/generative-composer-plugin-tooling": "^1.2.0"
  },
  "require-dev": {
    "wyrihaximus/makefiles": "^0.7.12",
    "wyrihaximus/test-utilities": "^8.7.0"
  },
  "autoload": {
    "psr-4": {
      "Mammatus\\Groups\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mammatus\\Tests\\Groups\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "drupol/composer-packages": true,
      "ergebnis/composer-normalize": true,
      "icanhazstring/composer-unused": true,
      "infection/extension-installer": true,
      "mammatus/cron": true,
      "mindplay/composer-locator": true,
      "phpstan/extension-installer": true,
      "wyrihaximus/broadcast": true,
      "wyrihaximus/makefiles": true,
      "wyrihaximus/test-utilities": true
    },
    "platform": {
      "php": "8.4.13"
    },
    "sort-packages": true
  },
  "extra": {
    "class": "Mammatus\\Groups\\Composer\\Installer",
    "mammatus": {
      "has-groups": true
    },
    "wyrihaximus": {
      "broadcast": {
        "has-listeners": true
      }
    }
  },
  "scripts": {
    "post-install-cmd": [
      "make on-install-or-update || true"
    ],
    "post-update-cmd": [
      "make on-install-or-update || true"
    ],
    "pre-autoload-dump": [
      "Mammatus\\Groups\\Composer\\Installer::findGroups"
    ],
    "generate-config": [
      "Mammatus\\Groups\\Composer\\Installer::findGroups"
    ]
  }
}
